# OpenClaw Gateway 配置
# WebSocket 连接地址（已自动检测）
VITE_GATEWAY_URL=wss://loylin.com/openclaw

# Gateway 认证 Token（必需）
# 获取方式：在 OpenClaw Gateway 服务器上运行命令获取带 token 的 URL
# 命令：openclaw dashboard
# 或从 Gateway 配置文件中获取 token
VITE_GATEWAY_TOKEN=e41aaf1ec696fa0f69e305522614688b1f3f25d54ea46b16

# 启用调试模式（帮助诊断连接问题）
VITE_DEBUG=true