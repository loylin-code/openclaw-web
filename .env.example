# OpenClaw Gateway 配置示例
# 复制此文件为 .env 并填写实际值

# WebSocket 连接地址
# 本地 Gateway: ws://localhost:18789
# 远程 Gateway: wss://your-domain.com/ws 或 wss://your-domain.com/openclaw/ws
VITE_GATEWAY_URL=wss://loylin.com/openclaw/ws

# Gateway 认证 Token
# 从 OpenClaw Gateway 配置文件中获取 (~/.openclaw/openclaw.json 的 gateway.auth.token)
# 或通过设备配对流程获取
VITE_GATEWAY_TOKEN=